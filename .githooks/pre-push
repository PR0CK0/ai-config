#!/usr/bin/env bash
# pre-push — block push if AGENTS.md was changed without rebuilding aliases.
# Install: run ./build.sh (sets core.hooksPath automatically).
set -euo pipefail

AGENTS="AGENTS.md"
GENERATED=(claude/CLAUDE.md gemini/GEMINI.md codex/AGENTS.md cursor/user-rules.md cursor/rules/global.mdc)

# Only run if AGENTS.md is among the changed files being pushed
changed=$(git diff --name-only HEAD @{u} 2>/dev/null || git diff --name-only HEAD 2>/dev/null)
if ! echo "$changed" | grep -q "^${AGENTS}$"; then
  exit 0
fi

# Check if any generated file is older than AGENTS.md
needs_rebuild=0
for f in "${GENERATED[@]}"; do
  if [[ ! -f "$f" ]] || [[ "$AGENTS" -nt "$f" ]]; then
    needs_rebuild=1
    break
  fi
done

if [[ "$needs_rebuild" -eq 0 ]]; then
  exit 0
fi

echo "AGENTS.md changed — rebuilding aliases..."
bash build.sh

echo ""
echo "Generated files updated. Stage and commit them before pushing:"
for f in "${GENERATED[@]}"; do
  echo "  git add $f"
done
echo "  git commit -m 'chore: rebuild aliases from AGENTS.md'"
echo ""
exit 1
